datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model WaitlistSignup {
  id                Int       @id @default(autoincrement())
  email             String
  sourceInput       String?   // Website URL or null for manual
  inputType         InputType
  status            JobStatus @default(PENDING)
  rawExtractedText  String?   @db.Text
  dnaJson           Json?
  answersJson       Json?     // Interactive Discovery Workbook answers
  rawMarkdown       String?   @db.Text  // The rendered Markdown strategy document
  mdFileUrl         String?   // Local relative URL: /generated-dna/{id}.md
  isLikelyBusinessEmail Boolean   @default(false)
  faviconUrl        String?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  completedAt       DateTime?
  visualIdentity    BrandVisualIdentity?
}

model BrandVisualIdentity {
  id                 Int                  @id @default(autoincrement())
  waitlistId         Int                  @unique
  waitlist           WaitlistSignup       @relation(fields: [waitlistId], references: [id])

  status             GuidelineStatus      @default(NOT_STARTED)
  archetypeCluster   String?

  brandColorHex      String?
  typographyJson     Json?

  logoUrl            String?
  imageryUrls        String[]             // 3 Values images
  mockupUrls         Json?                // { businessCards: [...], appIcon, socialFrames: [...], tier2: {...} }

  failureReason      String?
  emailSentAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model MockupTemplate {
  id                   Int      @id @default(autoincrement())
  templateId           String   @unique
  // "apparel" | "stationery" | "digital" | "physical" | "environment"
  category             String
  // Blob URL — the empty base scene (no logo, no overlay)
  baseImageUrl         String
  // Blob URL — optional shadow/reflection/highlight overlay composited ABOVE the logo
  overlayImageUrl      String?
  garmentMaskUrl       String?

  // 4-corner perspective quad in pixel coordinates relative to baseImageUrl's actual dimensions.
  // { topLeft: {x,y}, topRight: {x,y}, bottomRight: {x,y}, bottomLeft: {x,y} }
  // Null only for requiresDisplacement:true entries (deferred — no quad applicable).
  logoZoneJson         Json?

  // Design-layer blend settings read from Photopea layer panel
  blendMode            String   @default("normal") // "normal"|"multiply"|"linear-burn"|"screen"|"overlay"
  layerOpacity         Int      @default(100)       // 0–100, maps to Photopea Opacity
  layerFill            Int      @default(100)       // 0–100, maps to Photopea Fill

  // true = requires Displace Smart Filter; sharp cannot reproduce this — template is seeded inactive and deferred
  requiresDisplacement Boolean  @default(false)
  active               Boolean  @default(false)    // default false — must be explicitly activated after Photopea verification
  compositePrompt      String   @default("")       // prompt describing how the logo should sit on this surface for generative compositing
  createdAt            DateTime @default(now())
}

enum InputType {
  WEBSITE
  MANUAL
  QUESTIONNAIRE
}

enum JobStatus {
  PENDING
  EXTRACTING
  GENERATING
  DONE
  FAILED
}

enum GuidelineStatus {
  NOT_STARTED
  QUEUED
  GENERATING
  COMPLETE
  FAILED
}

model GeneratedMockup {
  id            String   @id @default(cuid())
  waitlistId    Int
  templateId    String
  logoVersion   String   // hash or version stamp of BrandVisualIdentity.logoUrl content
  resultUrl     String?  @db.Text // Blob URL once generation succeeds
  status        String   @default("pending") // "pending" | "generating" | "ready" | "failed" | "fallback"
  errorMessage  String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([waitlistId, templateId, logoVersion])
}
